# App stage
APP_ENV=staging
NEXT_PUBLIC_APP_ENV=staging

# Firebase Client
NEXT_PUBLIC_FIREBASE_API_KEY=replace-with-staging-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=replace-with-staging-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=replace-with-staging-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=replace-with-staging-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace-with-staging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=replace-with-staging-app-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=replace-with-staging-measurement-id

# Shared collection names
NEXT_PUBLIC_COLLECTION_CONCLAVES=conclaves
NEXT_PUBLIC_COLLECTION_LOGIN_LOGS=loginLogs
NEXT_PUBLIC_COLLECTION_MONTHLY_MEETING=monthlyMeetings
NEXT_PUBLIC_COLLECTION_PAGE_VISIT=pageVisits
NEXT_PUBLIC_COLLECTION_REFERRAL=referrals
NEXT_PUBLIC_COLLECTION_BIRTHDAY_CANVA=birthdayCanva
NEXT_PUBLIC_COLLECTION_USER_DETAIL=userdetails
NEXT_PUBLIC_COLLECTION_PROSPECT=prospects
NEXT_PUBLIC_COLLECTION_DOORSTEP=doorstep
NEXT_PUBLIC_COLLECTION_ORBITER=orbiters

# Server-side Firebase Admin
FIREBASE_PROJECT_ID=replace-with-staging-project-id
FIREBASE_CLIENT_EMAIL=replace-with-staging-adminsdk-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-staging-private-key\n-----END PRIVATE KEY-----\n"

# Other server secrets
WHATSAPP_PHONE_NUMBER_ID=replace-with-staging-whatsapp-phone-number-id
WHATSAPP_ACCESS_TOKEN=replace-with-staging-whatsapp-access-token
OPENAI_API_KEY=replace-with-openai-api-key
JWT_SECRET=replace-with-staging-jwt-secret
ADMIN_JWT_SECRET=replace-with-staging-admin-jwt-secret
